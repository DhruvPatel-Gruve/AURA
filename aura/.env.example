# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development                   # development | production
APP_SECRET_KEY=change-me-32-chars-min # required — any random 32+ char string; also
                                       # derives the key used to encrypt tenants'
                                       # ITSM API tokens at rest

# ── Bootstrap master_admin account ────────────────────────────────────────────
# Seeded once on first startup (only if no master_admin exists yet). Log in
# with this to create your first tenant from the Master Admin > Tenants page.
# Change it immediately after first login — a startup guard actively blocks
# the insecure default password when APP_ENV=production.
DEFAULT_ADMIN_EMAIL=admin@aura.local
DEFAULT_ADMIN_PASSWORD=changeme123

# ── Gemini (embeddings only — not used for resolution generation) ─────────────
GEMINI_API_KEY=your-gemini-api-key    # required — https://aistudio.google.com/apikey
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-2
GEMINI_EMBEDDING_BATCH_SIZE=100

# ── Qdrant ─────────────────────────────────────────────────────────────────────
# `docker compose up -d` (from the repo root) starts a local instance matching
# this default URL — nothing else to configure for local development.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                       # leave empty for local Qdrant
QDRANT_VECTOR_SIZE=768

# ── SQLite ─────────────────────────────────────────────────────────────────────
SQLITE_DB_PATH=./aura.db

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_DIR=./logs
LOG_MAX_BYTES=5000000                 # rotate each file at ~5MB
LOG_BACKUP_COUNT=5

# ── Scheduler ──────────────────────────────────────────────────────────────────
INGESTION_SYNC_INTERVAL_HOURS=6
INGESTION_LOOKBACK_DAYS=90

# ── JWT Auth ───────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM — used to draft ticket resolutions ────────────────────────────────────
# Any OpenAI-compatible chat completions endpoint: a local Ollama server
# (`ollama pull qwen3:8b && ollama serve`), a remote vLLM server, or any
# hosted OpenAI-compatible API. Not needed to start the app or create
# tenants — only needed once a tenant actually processes a ticket.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:8b

# ── CORS — add your frontend's origin if not running on the default port ──────
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
