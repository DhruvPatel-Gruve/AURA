# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development                   # development | production
APP_SECRET_KEY=change-me-32-chars-min
AURA_ENABLED=true                     # Global kill switch

# ── ITSM provider ──────────────────────────────────────────────────────────────
# Which backend AURA talks to: "jira" or "zendesk". This is just the boot-time
# seed — the admin can switch providers later via the setup wizard without a
# restart (see app/services/itsm_provider_state.py). Only the fields for
# whichever provider is actually active need to be filled in below.
ITSM_PROVIDER=jira

# ── Jira Service Management (used when ITSM_PROVIDER=jira) ────────────────────
JSM_BASE_URL=https://your-domain.atlassian.net
JSM_PROJECT_KEY=ITSM
JSM_API_EMAIL=your-email@example.com
JSM_API_TOKEN=your-atlassian-api-token

# ── Zendesk (used when ITSM_PROVIDER=zendesk) ──────────────────────────────────
ZEN_SUBDOMAIN=your-subdomain            # from https://<subdomain>.zendesk.com
ZEN_API_EMAIL=your-email@example.com
ZEN_API_TOKEN=your-zendesk-api-token

# ── Gemini (text-embedding-004) ────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
GEMINI_EMBEDDING_BATCH_SIZE=100

# ── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                       # Leave empty for local Qdrant
QDRANT_RESOLVED_COLLECTION=resolved_tickets
QDRANT_VECTOR_SIZE=768

# ── SQLite ─────────────────────────────────────────────────────────────────────
SQLITE_DB_PATH=./aura.db

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_DIR=./logs                        # backend.log + frontend.log written here
LOG_MAX_BYTES=5000000                 # rotate each file at ~5MB
LOG_BACKUP_COUNT=5

# ── Scheduler ──────────────────────────────────────────────────────────────────
INGESTION_SYNC_INTERVAL_HOURS=6
INGESTION_LOOKBACK_DAYS=90

# ── JWT Auth (Phase 1) ─────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM — Qwen3 8B via Ollama (Phase 1) ───────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:8b
